# --- Copy to .env.prod on the VPS (NEVER commit .env.prod) ---

# Postgres
POSTGRES_USER=agente10
POSTGRES_PASSWORD=__GENERATE_STRONG_PASSWORD__
POSTGRES_DB=agente10

# Domain pointing to this VPS (A record). Caddy uses this for HTTPS via Let's Encrypt.
DOMAIN=api.seudominio.com

# Frontend origin(s) allowed by CORS, comma-separated.
# Inclua o domínio Vercel + qualquer staging.
CORS_ALLOW_ORIGINS=https://agente10.vercel.app,https://agente10-preview.vercel.app

# Optional APIs
VOYAGE_API_KEY=
VOYAGE_MODEL=voyage-3
ANTHROPIC_API_KEY=
